{
  "name": "sofian/my-cinema",
  "description": "Cinema Dashboard using MVC Design Pattern",
  "type": "project",
  "license": "Unlicense",
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Tests\\": "tests/"
